# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# Enrichment
# Apollo (paid, monthly): LinkedIn URL -> current company + domain + email in one call
APOLLO_API_KEY=
# Proxycurl (paid, pay-per-lookup): LinkedIn URL -> authoritative current employer + title
PROXYCURL_API_KEY=
HUNTER_API_KEY=
# Serper.dev (Google search) — resolves the company's real domain from its name
SERPER_API_KEY=

# Drafting (OpenAI-compatible API)
# DeepSeek (default): base_url https://api.deepseek.com, model deepseek-chat
# Qwen (DashScope): base_url https://dashscope-intl.aliyuncs.com/compatible-mode/v1, model qwen-plus
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Gmail (IMAP app password — turn on 2-Step Verification, enable IMAP, generate a 16-char app password)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Knowledge base: locally it reads kb/*.local.md files. On a host (e.g. Railway),
# paste your whole KB markdown into KB_TEXT instead (keeps personal info out of the repo).
KB_TEXT=

# Email footer appended to every draft (optional; a sensible default is built in)
EMAIL_FOOTER=
# Resume PDF attached to every draft: a local path (RESUME_PATH) or a hosted URL (RESUME_URL, for cloud)
RESUME_PATH=
RESUME_URL=
